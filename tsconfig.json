{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "strict": true,
    "baseUrl": ".",
    "outDir": "dist",
    "typeRoots": [
      "./src/types"
    ],
    "paths": {
      "modlib": ["./src/modlib"],
      "modlib/*": ["./src/modlib/*"],
      "bf6-portal-utils/*": ["./src/bf6-portal-utils/*"]
    }
  }
}
